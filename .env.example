# Base MCP Server Environment Configuration

# Coinbase API Credentials (Required)
COINBASE_API_KEY_NAME=your_api_key_name_here
COINBASE_API_PRIVATE_KEY=your_private_key_here

# Wallet Configuration (Required for trading)
SEED_PHRASE=your_wallet_seed_phrase_here

# Network Configuration (Optional)
CHAIN_ID=8453  # Base mainnet (8453) or Base Sepolia testnet (84532)

# MCP API Configuration (Optional)
MCP_API_PORT=4000

# Optional Service API Keys
ALCHEMY_API_KEY=your_alchemy_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
NEYNAR_API_KEY=your_neynar_api_key
PINATA_JWT=your_pinata_jwt

# Trading System Configuration (Optional - can be set via MCP actions)
# TRADING_MAX_POSITION_SIZE=1000
# TRADING_RISK_PER_TRADE=0.02
# TRADING_FREQUENCY=30